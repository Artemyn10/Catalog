@model Catalog.Models.Recipe

@{
    ViewData["Title"] = "Создание рецепта";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Создание нового рецепта</h2>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()  <!-- Ключевой элемент для POST -->

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Название</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CookingTime" class="form-label">Время приготовления (минут)</label>
                            <input asp-for="CookingTime" class="form-control" type="number" min="1" />
                            <span asp-validation-for="CookingTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Difficulty" class="form-label">Сложность</label>
                            <select asp-for="Difficulty" class="form-select">
                                <option value="">Выберите сложность</option>
                                <option value="Легко">Легко</option>
                                <option value="Средне">Средне</option>
                                <option value="Сложно">Сложно</option>
                            </select>
                            <span asp-validation-for="Difficulty" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Категория</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-orange btn-lg">Создать рецепт</button>
                            <a asp-action="Index" class="btn btn-secondary ms-3">Назад к списку</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}