@model Catalog.Models.EditProfileDto

@{
    ViewData["Title"] = "Редактирование профиля";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="text-center mb-4">Редактирование профиля</h2>

    @if (TempData["SuccessProfile"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessProfile"]</div>
    }
    @if (TempData["SuccessPassword"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessPassword"]</div>
    }

    <div class="text-center mb-4">
        @if (!string.IsNullOrEmpty(ViewBag.CurrentAvatar as string))
        {
            <img src="@ViewBag.CurrentAvatar" class="rounded-circle shadow" width="150" height="150" alt="Аватар" style="object-fit: cover;" />
            <div class="mt-3">
                <form asp-action="DeleteAvatar" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm">Удалить аватар</button>
                </form>
            </div>
        }
        else
        {
            <i class="fas fa-user-circle fa-5x text-orange shadow"></i>
        }
    </div>

    <!-- Форма для имени, email и аватара -->
    <form asp-action="EditProfile" method="post" enctype="multipart/form-data" class="mb-5">
        <div class="mb-3">
            <label class="form-label fw-bold">Имя</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Изменить аватар</label>
            <input type="file" name="avatar" class="form-control" accept="image/jpeg,image/png" />
            <small class="text-muted">JPG или PNG, до 2 МБ</small>
        </div>
        <button type="submit" class="btn btn-warning w-100 fw-bold">Сохранить изменения профиля</button>
    </form>

    <!-- Форма для изменения пароля -->
    <h4 class="mt-5">Изменение пароля</h4>
    <form asp-action="ChangePassword" method="post">
        <div class="mb-3">
            <label class="form-label fw-bold">Текущий пароль</label>
            <input asp-for="CurrentPassword" type="password" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Новый пароль</label>
            <input asp-for="NewPassword" type="password" class="form-control" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Подтвердите новый пароль</label>
            <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
        </div>
        <button type="submit" class="btn btn-warning w-100 fw-bold">Изменить пароль</button>
    </form>

    <div class="text-center mt-4">
        <a href="/User/Profile">Вернуться в профиль</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}