@model Catalog.Models.User

@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Личный кабинет</h2>
    
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center mb-4">
                    <div class="d-flex flex-column align-items-center">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" class="rounded-circle shadow" width="150" height="150" alt="Аватар профиля" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="default-avatar rounded-circle shadow d-flex align-items-center justify-content-center" style="width: 150px; height: 150px; background-color: #ff8c00;">
                            <i class="fas fa-user fa-4x text-white"></i>
                        </div>
                    }
                    <h4 class="mt-3">@Model.Username</h4>
                    <p class="text-muted">@Model.Role</p>
                    <a href="/User/Edit" class="btn btn-orange btn-sm d-md-none mt-3">Редактировать профиль</a>
                    </div>
                </div>
                <div class="col-md-8">
                    <h5>Информация о профиле</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
                        <li class="list-group-item"><strong>Дата регистрации:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy")</li> 
                        <li class="list-group-item"><strong>Роль:</strong> @Model.Role</li>
                    </ul>
                    <!-- Кнопка редактирования на десктопе (справа от списка) -->
                    <div class="mt-4 d-none d-md-block">
                        <a href="/User/Edit" class="btn btn-orange">Редактировать профиль</a>
                    </div>      
                </div>
            </div>
        </div>
    </div>
    
    <h4 class="mt-5 mb-3">Мои рецепты (@Model.Recipes.Count)</h4>
    @if (Model.Recipes.Any())
    {
        <div class="row">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <!-- Placeholder для фото рецепта -->
                        <img src="~/images/placeholder.jpg" class="card-img-top" alt="@recipe.Title">
                        <div class="card-body">
                            <h5 class="card-title">@recipe.Title</h5>
                            <a href="/Recipes/Details/@recipe.Id" class="btn btn-orange btn-sm">Подробнее</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">У вас пока нет добавленных рецептов.</p>
        <a href="/Recipes/Create" class="btn btn-orange">Добавить рецепт</a>    
    }
</div>

<style>
    .text-orange { color: #ff8c00; }
    .btn-orange { background-color: #ff8c00; color: white; }
    .btn-orange:hover { background-color: #e67b00; }
</style>    