@model IEnumerable<Catalog.Models.Recipe>

@{
    ViewData["Title"] = "Избранное";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Избранное (@Model.Count())</h2>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var recipe in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        @if (recipe.Photos.Any())
                        {
                            <img src="@recipe.Photos.First().PhotoUrl" class="card-img-top" alt="@recipe.Title">
                        }
                        else
                        {
                            <img src="~/images/placeholder.jpg" class="card-img-top" alt="@recipe.Title">
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@recipe.Title</h5>
                            <p class="text-muted small">Автор: @recipe.User.Username</p>
                            <a href="/Recipes/Details/@recipe.Id" class="btn btn-orange btn-sm mt-auto">Подробнее</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">У вас пока нет избранных рецептов.</p>
            <a href="/Recipes/Index" class="btn btn-orange">Перейти к рецептам</a>
        </div>
    }
</div>